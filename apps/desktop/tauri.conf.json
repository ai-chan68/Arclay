{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EasyWork",
  "version": "0.1.0",
  "identifier": "com.easywork.app",
  "build": {
    "beforeDevCommand": "pnpm dev:all",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build && pnpm build:api",
    "frontendDist": "../src/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "EasyWork",
        "width": 1200,
        "height": 800,
        "minWidth": 1120,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/easywork-api"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13"
    },
    "windows": {
      "digestAlgorithm": "sha256"
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
