{
  "name": "ease-work",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "./scripts/start.sh",
    "start:api": "./scripts/start.sh --api-only",
    "start:web": "./scripts/start.sh --web-only",
    "start:tauri": "./scripts/start.sh --tauri",
    "start:clean": "./scripts/start.sh --clean",
    "dev:web": "pnpm --filter src dev",
    "dev:api": "pnpm --filter src-api dev",
    "dev:all": "pnpm run dev:api & pnpm run dev:web",
    "dev": "pnpm tauri dev",
    "build": "pnpm -r build",
    "build:api": "./scripts/build-api-binary.sh",
    "build:api:all": "./scripts/build-api-binary.sh --all",
    "build:desktop": "pnpm build && pnpm build:api && pnpm tauri build",
    "release:prepare-assets": "node ./scripts/prepare-release-assets.mjs",
    "typecheck": "node ./scripts/quality-runner.mjs typecheck src src-api shared-types",
    "lint": "node ./scripts/quality-runner.mjs lint src src-api shared-types",
    "check:api-fetch": "./scripts/check-api-fetch.sh",
    "smoke:desktop": "node ./scripts/smoke-desktop.mjs",
    "smoke:desktop:with-api": "node ./scripts/run-smoke-with-api.mjs",
    "test": "node ./scripts/quality-runner.mjs test src src-api shared-types",
    "pre-release": "node ./scripts/pre-release.mjs"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.0.0",
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@yao-pkg/pkg": "^5.12.0",
    "esbuild": "^0.25.0"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@types/prismjs": "^1.26.6",
    "exceljs": "^4.4.0",
    "fontfaceobserver": "^2.3.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.11.0",
    "pptxgenjs": "^4.0.1",
    "prismjs": "^1.30.0",
    "react-hotkeys-hook": "^5.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "remark-gfm": "^4.0.1",
    "xlsx": "^0.18.5"
  }
}
